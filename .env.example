# Cisco Secure Firewall Management Center (FMC) connection settings.
# Copy to .env and fill in. Never commit .env.
FMC_URL=https://192.0.2.11
FMC_USERNAME=admin
FMC_PASSWORD=changeme
# Domain to operate in (name); defaults to the token's default (Global) domain.
FMC_DOMAIN=Global
# Verify the FMC TLS certificate (labs usually use self-signed).
FMC_VERIFY_SSL=false
# Per-request timeout in seconds.
FMC_TIMEOUT=60
